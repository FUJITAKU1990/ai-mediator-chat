# OpenAI (mediation features)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
PORT=3000

# Supabase — Project Settings → API (use anon or publishable public key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=

# Server-only: Secret key (service_role) — for saving private reaction totals. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=
